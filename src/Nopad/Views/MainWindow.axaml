<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noopad.ViewModels"
        xmlns:views="using:Noopad.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Noopad.Views.MainWindow"
        Title="noopad"
        Icon="/Assets/noopad.ico"
        MinWidth="600" MinHeight="400"
        Width="1200" Height="700">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAllCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding ShowFindPanelCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ShowReplacePanelCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Tab" Command="{Binding NewTabCommand}" InputGesture="Ctrl+T"/>
                <MenuItem Header="Open File..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S"/>
                <MenuItem Header="Save As..." Command="{Binding SaveAsCommand}"/>
                <MenuItem Header="Save All" Command="{Binding SaveAllCommand}" InputGesture="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="Close Tab" Command="{Binding CloseTabCommand}" InputGesture="Ctrl+W"/>
                <MenuItem Header="Close All" Command="{Binding CloseAllTabsCommand}"/>
                <Separator/>
                <MenuItem Header="Exit" x:Name="MenuExit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Undo" x:Name="MenuUndo" InputGesture="Ctrl+Z"/>
                <MenuItem Header="Redo" x:Name="MenuRedo" InputGesture="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Cut" x:Name="MenuCut" InputGesture="Ctrl+X"/>
                <MenuItem Header="Copy" x:Name="MenuCopy" InputGesture="Ctrl+C"/>
                <MenuItem Header="Paste" x:Name="MenuPaste" InputGesture="Ctrl+V"/>
                <MenuItem Header="Select All" x:Name="MenuSelectAll" InputGesture="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle Word Wrap" Command="{Binding ToggleWordWrapCommand}"/>
                <MenuItem Header="Toggle Line Numbers" Command="{Binding ToggleLineNumbersCommand}"/>
                <MenuItem Header="Toggle Markdown Preview" Command="{Binding ToggleMarkdownPreviewCommand}"/>
            </MenuItem>
            <MenuItem Header="_Search">
                <MenuItem Header="Find" Command="{Binding ShowFindPanelCommand}" InputGesture="Ctrl+F"/>
                <MenuItem Header="Find Next" x:Name="MenuFindNext" InputGesture="F3"/>
                <MenuItem Header="Find Previous" x:Name="MenuFindPrev" InputGesture="Shift+F3"/>
                <MenuItem Header="Replace" Command="{Binding ShowReplacePanelCommand}" InputGesture="Ctrl+H"/>
            </MenuItem>
            <MenuItem Header="F_ormat">
                <MenuItem Header="Format JSON" Command="{Binding FormatJsonCommand}"/>
                <MenuItem Header="Format XML" Command="{Binding FormatXmlCommand}"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Preferences..." Command="{Binding ShowSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" x:Name="MenuAbout"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Padding="8,3">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"/>
        </Border>

        <!-- Search/Replace Panel -->
        <views:SearchReplacePanel DockPanel.Dock="Bottom"
                                   DataContext="{Binding SearchPanel}"
                                   IsVisible="{Binding SearchPanel.IsVisible}"/>

        <!-- Tab Bar + Editor Area -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Strip -->
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TabStrip" ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:EditorTabViewModel">
                            <Button x:Name="TabButton"
                                    Padding="0"
                                    Margin="1,2,1,0"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="10,5,6,5">
                                    <Ellipse Width="8" Height="8" Fill="OrangeRed"
                                             IsVisible="{Binding IsDirty}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                    <Button x:Name="CloseTabBtn"
                                            Content="&#x2715;"
                                            FontSize="10"
                                            Padding="2,0"
                                            Margin="2,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Editor Content -->
            <ContentControl Grid.Row="1" Content="{Binding ActiveTab}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:EditorTabViewModel">
                        <views:EditorDocumentView/>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>
    </DockPanel>
</Window>
