<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Noopad.Views.AboutDialog"
        Title="About noopad"
        Width="320" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <StackPanel Margin="24" Spacing="10" VerticalAlignment="Center">
        <TextBlock Text="noopad" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="// noop pad — engineering edition" HorizontalAlignment="Center" Foreground="Gray" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
        <TextBlock Text="A tabbed engineer text editor" HorizontalAlignment="Center" Foreground="Gray"/>
        <TextBlock Text="Built with Avalonia and AvaloniaEdit" HorizontalAlignment="Center" FontSize="11" Foreground="Gray"/>
        <Button Content="OK" HorizontalAlignment="Center" Margin="0,12,0,0" Width="80"
                Click="OkClick"/>
    </StackPanel>
</Window>